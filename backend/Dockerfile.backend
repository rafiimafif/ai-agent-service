FROM node:20-alpine AS builder

RUN apk add --no-cache openssl git

WORKDIR /app

COPY package.json ./
# SQLite might need specific build tools on alpine so we make it simple
RUN npm install

COPY . .

RUN npx prisma generate
RUN npm run build

FROM node:20-alpine AS runner

RUN apk add --no-cache openssl git

WORKDIR /app

COPY --from=builder /app/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/prisma ./prisma

EXPOSE 5000

ENV PORT=5000
ENV NODE_ENV=production
ENV DATABASE_URL="file:/app/prisma/data/dev.db"

# At runtime, ensure data dir exists, push database schema, seed, and start server
CMD mkdir -p /app/prisma/data && npx prisma db push && npx prisma db seed && node dist/server.js
